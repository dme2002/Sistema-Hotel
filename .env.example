# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (MariaDB)
# ============================================
DB_NAME=hotel_management
DB_USER=hotel_user
DB_PASSWORD=tu_password_seguro
DB_HOST=db          # normalmente el nombre del servicio de MariaDB en docker-compose
DB_PORT=3306

# ============================================
# CONFIGURACIÓN DJANGO
# ============================================
DJANGO_SECRET_KEY=django-insecure-change-this-in-production-very-long-secret-key-123456789
ALLOWED_HOSTS=localhost,127.0.0.1,nginx,backend

# ============================================
# CONFIGURACIÓN FASTAPI
# ============================================
FASTAPI_SECRET_KEY=fastapi-secure-secret-key-change-in-production-very-long-123456789
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============================================
# CONFIGURACIÓN CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:80
